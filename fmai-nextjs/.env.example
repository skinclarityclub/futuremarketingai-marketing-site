# =============================================================================
# FutureMarketingAI — Marketing Website Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# For the SaaS application (fma-app) see C:/Users/daley/Desktop/fma-app/.env.example

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://future-marketing.ai

# Anthropic — used by the Clyde chatbot widget (/api/chatbot)
ANTHROPIC_API_KEY=sk-ant-xxx

# Resend — application form email delivery (/api/apply)
# Optional: if not set, /api/apply logs submissions to server console
RESEND_API_KEY=re_xxx
APPLY_EMAIL_TO=hello@future-marketing.ai
APPLY_EMAIL_FROM=apply@future-marketing.ai

# Contact form email delivery (/api/contact)
CONTACT_EMAIL_TO=hello@future-marketing.ai
CONTACT_EMAIL_FROM=contact@future-marketing.ai

# Supabase — applications and contact_submissions tables live here (server-only)
# Used by /api/apply and /api/contact to persist leads alongside the Resend email.
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Upstash Redis — cross-isolate rate-limit for /api/apply and /api/contact
# Free tier is enough. Use EU region (Frankfurt) for AVG.
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxx

# Salt for hashing visitor IPs before storing in Supabase (AVG: never store raw IPs).
IP_HASH_SALT=change-me-to-a-random-32-char-string

# Google Tag Manager (optional analytics)
NEXT_PUBLIC_GTM_ID=

# Calendly inline widget for ApplicationForm + ContactForm success states (Phase 15-02).
# Enable "Use questions as URL parameters" in Calendly dashboard for prefill to work:
# Calendly.com -> Event Types -> [strategy-call] -> Settings -> Invitee Questions.
NEXT_PUBLIC_CALENDLY_APPLY_URL=https://calendly.com/futureai/strategy-call

# Newsletter + lead magnet (Phase 15-04)
# Resend Audience for the FMai newsletter. Create in Resend dashboard:
# Audiences -> [Create "FMai Newsletter NL"] -> copy the audience ID.
# When unset, /api/newsletter/confirm still flips the consent row to confirmed
# and sends the PDF link, but the contact will NOT be added to the audience
# (a non-fatal warning is logged server-side).
RESEND_AUDIENCE_ID=

# Vercel Analytics (auto-injected on Vercel deployments)

# =============================================================================
# Stripe — reference only. Marketing site does NOT call Stripe directly.
# All subscription + Stripe integration lives in fma-app SaaS command center.
# Website mirrors the tier prices via src/lib/pricing-data.ts (which mirrors
# fma-app/src/lib/skills.ts). Keep these variables documented for future use
# if website gains a checkout flow.
#
# Pricing model since 2026-04-28: Founding is fixed (€997/mo lifetime),
# Growth/Pro/Enterprise are workspace-priced (linear: pricePerWorkspace ×
# workspaces). When activating a checkout flow, prefer Stripe quantity-based
# subscriptions (workspaces as seats) over a price-ID per workspace count.
# =============================================================================
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_PRICE_GROWTH_PER_WORKSPACE=price_xxx      # €499/workspace/mo, qty 2-4
# STRIPE_PRICE_PROFESSIONAL_PER_WORKSPACE=price_xxx # €399/workspace/mo, qty 5-14
# STRIPE_PRICE_ENTERPRISE_PER_WORKSPACE=price_xxx   # €299/workspace/mo, qty 15+
# STRIPE_PRICE_FOUNDING=price_xxx                   # €997/mo lifetime fixed
