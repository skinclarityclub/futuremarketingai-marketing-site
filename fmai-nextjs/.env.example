# =============================================================================
# FutureMarketingAI — Marketing Website Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# For the SaaS application (fma-app) see C:/Users/daley/Desktop/fma-app/.env.example

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://futuremarketingai.com

# Anthropic — used by the Clyde chatbot widget (/api/chatbot)
ANTHROPIC_API_KEY=sk-ant-xxx

# Resend — application form email delivery (/api/apply)
# Optional: if not set, /api/apply logs submissions to server console
RESEND_API_KEY=re_xxx
APPLY_EMAIL_TO=hello@futuremarketingai.com
APPLY_EMAIL_FROM=apply@futuremarketingai.com

# Contact form email delivery (/api/contact)
CONTACT_EMAIL_TO=info@futuremarketingai.com

# Google Tag Manager (optional analytics)
NEXT_PUBLIC_GTM_ID=

# Vercel Analytics (auto-injected on Vercel deployments)

# =============================================================================
# Stripe — reference only. Marketing site does NOT call Stripe directly.
# All subscription + Stripe integration lives in fma-app SaaS command center.
# Website just displays the tier prices (hardcoded in src/lib/skills-data.ts
# and shown on /pricing). Keep these variables documented for future use
# if website gains a checkout flow.
# =============================================================================
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_PRICE_PARTNER=price_xxx          # €347/mo
# STRIPE_PRICE_GROWTH=price_xxx           # €2497/mo
# STRIPE_PRICE_PROFESSIONAL=price_xxx     # €4497/mo
# STRIPE_PRICE_ENTERPRISE=price_xxx       # €7997/mo
# STRIPE_PRICE_FOUNDING=price_xxx         # €997/mo (grandfathered)
