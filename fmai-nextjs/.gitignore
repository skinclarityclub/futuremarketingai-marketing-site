# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# debug screenshots (moved from root in Phase 13-03)
.screenshots/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# Phase 16 audit artefacts (heavy binaries, raw outputs)
test-results/audit-v2/**/*.png
test-results/audit-v2/**/*.har
test-results/audit-v2/dom/**/*.html
test-results/audit-v2/axe/**/*.json
test-results/audit-v2/lighthouse/**/*.json
!test-results/audit-v2/screenshots/index.html

# Playwright's own managed dir (separated from test-results/ so audit-v2/ survives reruns)
/playwright-output/
